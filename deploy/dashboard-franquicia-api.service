[Unit]
Description=Dashboard Franquicia API (FastAPI)
After=network.target postgresql.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/var/www/dashboard-franquicia/backend
Environment="PATH=/var/www/dashboard-franquicia/backend/venv/bin"
ExecStart=/var/www/dashboard-franquicia/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
